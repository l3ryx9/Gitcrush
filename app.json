{
  "expo": {
    "name": "GitSync",
    "slug": "gitcrush",
    "owner": "loxyapping",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gitsync",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.loxyapping.gitcrush"
    },
    "android": {
      "package": "com.loxyapping.gitcrush"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "82c890b8-a7e0-499b-aa9d-15dff4f36a89"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/82c890b8-a7e0-499b-aa9d-15dff4f36a89"
    }
  }
}
